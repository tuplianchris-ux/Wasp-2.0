generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  role         Role          @default(STUDENT)
  createdAt    DateTime      @default(now())
  assignments  Assignment[]
  submissions  Submission[]
  testAttempts TestAttempt[]
  libraryItems LibraryItem[]
}

enum Role {
  TEACHER
  STUDENT
}

model Assignment {
  id          String       @id @default(cuid())
  title       String
  description String
  dueDate     DateTime
  fileUrl     String?
  createdBy   User         @relation(fields: [userId], references: [id])
  userId      String
  submissions Submission[]
  createdAt   DateTime     @default(now())
}

model Test {
  id        String        @id @default(cuid())
  title     String
  type      TestType      @default(QUIZ)
  questions String        // JSON array of Question objects
  timeLimit Int?
  published Boolean       @default(false)
  createdAt DateTime      @default(now())
  attempts  TestAttempt[]
}

enum TestType {
  QUIZ
  TEST
  EXAM
}

model TestAttempt {
  id          String   @id @default(cuid())
  student     User     @relation(fields: [userId], references: [id])
  userId      String
  test        Test     @relation(fields: [testId], references: [id])
  testId      String
  answers     String   // JSON
  score       Float?
  autoGraded  Boolean  @default(false)
  feedback    String?  // JSON array of per-question feedback
  submittedAt DateTime @default(now())
}

model Submission {
  id           String     @id @default(cuid())
  student      User       @relation(fields: [userId], references: [id])
  userId       String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  assignmentId String
  fileUrl      String?
  textContent  String?
  grade        Float?
  feedback     String?
  submittedAt  DateTime   @default(now())
}

model LibraryItem {
  id        String   @id @default(cuid())
  title     String
  type      String   // "file" | "link"
  url       String
  tags      String   // JSON array of strings
  addedBy   User     @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime @default(now())
}
